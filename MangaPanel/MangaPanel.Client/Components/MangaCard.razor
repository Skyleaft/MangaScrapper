@using MangaScrapper.Shared.Models

<div class="group bg-white rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 border border-slate-100 overflow-hidden flex flex-col h-full">
    <div class="relative aspect-[3/4] overflow-hidden">
        @if (!string.IsNullOrEmpty(Manga.LocalImageUrl))
        {
            <img src="/images/@Manga.LocalImageUrl" alt="@Manga.Title" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500" />
        }
        else if (!string.IsNullOrEmpty(Manga.ImageUrl))
        {
            <img src="@Manga.ImageUrl" alt="@Manga.Title" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500" />
        }
        
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center p-4">
            <button @onclick="() => OnDetailClick.InvokeAsync(Manga)" class="w-full py-2 bg-primary hover:bg-primary/90 text-white rounded-lg font-medium transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 shadow-lg">
                View Details
            </button>
        </div>
        
        <div class="absolute top-3 left-3 flex flex-wrap gap-1">
            <span class="px-2 py-1 bg-white/90 backdrop-blur-sm text-secondary text-[10px] font-bold uppercase tracking-wider rounded shadow-sm">@Manga.Type</span>
            @if (Manga.Rating.HasValue)
            {
                <span class="px-2 py-1 bg-yellow-400 text-white text-[10px] font-bold rounded shadow-sm flex items-center gap-0.5">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    @Manga.Rating.Value.ToString("F1")
                </span>
            }
        </div>
    </div>

    <div class="p-4 flex flex-col flex-grow">
        <h3 class="text-base font-bold text-slate-800 line-clamp-2 leading-tight mb-1 group-hover:text-primary transition-colors cursor-pointer" @onclick="() => OnDetailClick.InvokeAsync(Manga)" title="@Manga.Title">
            @Manga.Title
        </h3>
        <p class="text-xs text-slate-500 font-medium truncate mb-3">@Manga.Author</p>
        
        <div class="mt-auto">
            @if (Manga.LatestChapter != null)
            {
                <div class="flex items-center justify-between pt-3 border-t border-slate-50">
                    <span class="text-[11px] font-bold text-slate-400">Chapter @Manga.LatestChapter.Number</span>
                    <span class="text-[10px] text-slate-400">@Manga.LatestChapter.UploadDate.ToShortDateString()</span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public MangaSummary Manga { get; set; } = new();

    [Parameter]
    public EventCallback<MangaSummary> OnDetailClick { get; set; }
}
