<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <link rel="stylesheet" href="@Assets["app.css"]"/>
    <link rel="stylesheet" href="@Assets["MangaScrapper.styles.css"]"/>
    <ImportMap/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <HeadOutlet @rendermode="InteractiveWebAssembly"/>
</head>

<body>
<Routes @rendermode="InteractiveWebAssembly"/>
    <script>
            window.themeManager = {
                toggleDark: function () {
                    const isDark = document.documentElement.classList.toggle('dark');
                    localStorage.setItem('theme', isDark ? 'dark' : 'light');
                    return isDark;
                },
                initTheme: function () {
                    if (localStorage.getItem('theme') === 'dark' ||
                        (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                        document.documentElement.classList.add('dark');
                        return true;
                    }
                    document.documentElement.classList.remove('dark');
                    return false;
                }
            };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        window.createScrapChart = (canvasId, labels, data) => {
            const ctx = document.getElementById(canvasId);
            if (!ctx) return;

            if (window.myScrapChart) {
                window.myScrapChart.destroy();
            }

            window.myScrapChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Chapters Scrapped',
                        data: data,
                        fill: true,
                        borderColor: '#088395',
                        backgroundColor: 'rgba(8, 131, 149, 0.1)',
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#088395',
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: '#09637E',
                            titleColor: '#fff',
                            bodyColor: '#fff',
                            borderColor: '#088395',
                            borderWidth: 1,
                            padding: 10,
                            displayColors: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                display: true,
                                color: 'rgba(0,0,0,0.05)',
                                drawBorder: false
                            },
                            ticks: {
                                precision: 0
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    },
                    interaction: {
                        intersect: false,
                        mode: 'index',
                    }
                }
            });
        };
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>